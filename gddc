#!name= 📅 个人模块：高德打车签到
#!desc= 包含自动抓取 Cookie 和每日定时签到（标准多任务版，防折叠）
#!category= Custom

[Script]
# 1. 抓取 Cookie 脚本
amap_dache_cookie = type=http-response,pattern=^https?:\/\/(m5(|-zb)|dache)\.amap\.com\/(ws\/yuece\/(act|openapi\/activity\/current)\/query|common\/(alipaymini|wxmini)\?_ENCRYPT=),requires-body=1,max-size=0,script-path=https://fastly.jsdelivr.net/gh/wf021325/qx@master/task/ampDache.js,timeout=60,script-update-interval=86400

# 2. 定时自动签到（把 cronexp 的空格之间多加一层格式化，并移除了可能冲突的参数，逼迫 Surge 识别为双任务）
amap_dache_cron = type=cron,cronexp="15 10 * * *",script-path=https://fastly.jsdelivr.net/gh/wf021325/qx@master/task/ampDache.js,timeout=60,script-update-interval=86400

[MITM]
hostname = %APPEND% *.amap.com
