#!name= 📅 个人模块：高德打车-签到
#!desc= 专职高德打车自动签到。包含自动抓取 Cookie 与每日定时签到（独立版）。
#!category= 个人定制

[Script]
# 1. 自动抓取打车 Cookie (当你在高德 App 内进入打车页面时自动触发)
AMap_Dache_Cookie = type=http-request,pattern=^https?:\/\/.*\.amap\.com\/ws\/yuece\/act\/query,script-path=https://raw.githubusercontent.com/ClydeTime/Quantumult/main/Script/Task/ampDache.js,requires-body=0,timeout=60,script-update-interval=86400

# 2. 定时自动签到 (每天 10:15 自动运行)
AMap_Dache_Cron = type=cron,cronexp="15 10 * * *",script-path=https://raw.githubusercontent.com/ClydeTime/Quantumult/main/Script/Task/ampDache.js,wake-system=1,timeout=60,script-update-interval=86400

[MITM]
hostname = %APPEND% *.amap.com
