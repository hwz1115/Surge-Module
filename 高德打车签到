#!name= 📅 个人模块：高德打车全能版
#!desc= 包含高德打车：自动抓取 Cookie、每日定时签到、每日定时抢券（已修复脚本缺失与超时问题）。
#!category= 个人定制

[Script]
# 1. 抓取 Cookie 脚本（改名独立：AMap_Dache_Cookie）
AMap_Dache_Cookie = type=http-response,pattern=^https?:\/\/(m5(|-zb)|dache)\.amap\.com\/(ws\/yuece\/(act|openapi\/activity\/current)\/query|common\/(alipaymini|wxmini)\?_ENCRYPT=),script-path=https://fastly.jsdelivr.net/gh/wf021325/qx@master/task/ampDache.js,requires-body=1,timeout=60,script-update-interval=86400

# 2. 定时自动签到（改名独立：AMap_Dache_Cron）
AMap_Dache_Cron = type=cron,cronexp="15 10 * * *",script-path=https://fastly.jsdelivr.net/gh/wf021325/qx@master/task/ampDache.js,wake-system=1,timeout=60,script-update-interval=86400

# 3. 定时自动抢券（名字保持：AMap_Coupon_Cron）
AMap_Coupon_Cron = type=cron,cronexp="18 0 * * *",script-path=https://fastly.jsdelivr.net/gh/wf021325/qx@master/task/ampDacheCoupon.js,wake-system=1,timeout=60,script-update-interval=86400

[MITM]
hostname = %APPEND% *.amap.com
