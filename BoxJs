#!name= 🎛️ 个人模块：BoxJs 环境与备份中心
#!desc= 包含 BoxJs 每日定时自动备份，并在 Surge 首页提供“一键手动恢复数据”控制面板。
#!category= 个人定制

[Script]
# 1. BoxJs 数据自动备份 (每天 10:00 自动运行)
BoxJs_Backup = type=cron,cronexp="0 10 * * *",script-path=https://raw.githubusercontent.com/dompling/Script/master/gist/backup.js, wake-system=true, timeout=120

# 2. BoxJs 缓存历史纪录 (每天 10:05 自动运行)
BoxJs_Commit = type=cron,cronexp="10 10 * * *",script-path=https://raw.githubusercontent.com/dompling/Script/master/gist/commit.js, wake-system=true, timeout=120

# 3. BoxJs 首页手动恢复面板 (点击 Surge 首页的卡片即可手动触发恢复)
BoxJs_Manual_Restore = type=generic,timeout=10,script-path=https://raw.githubusercontent.com/dompling/Script/master/gist/restore.js,script-update-interval=0

[Panel]
# 在 Surge 首页生成一个可视化卡片
BoxJs_Manual_Restore = title="BoxJs 数据恢复", content="点击此处 🕒 手动恢复云端备份", icon="arrow.clockwise.icloud", script-name=BoxJs_Manual_Restore

[MITM]
hostname = %APPEND% boxjs.com, boxjs.net, *.boxjs.com, *.boxjs.net
